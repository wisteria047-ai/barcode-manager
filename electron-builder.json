{
  "appId": "com.barcode.manager",
  "productName": "バーコード管理ツール",
  "directories": {
    "output": "dist"
  },
  "files": [
    "src/**/*",
    "electron/**/*",
    "!node_modules/@capacitor/**",
    "!android/**",
    "!tests/**"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "src/assets/icons/icon-512.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "src/assets/icons/icon-512.png",
    "uninstallerIcon": "src/assets/icons/icon-512.png"
  },
  "mac": {
    "target": ["dmg"],
    "icon": "src/assets/icons/icon-512.png",
    "category": "public.app-category.business"
  }
}
